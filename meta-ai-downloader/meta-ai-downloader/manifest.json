{
  "manifest_version": 3,
  "name": "Meta AI Media Downloader",
  "version": "2.0.0",
  "description": "Meta AI videolarını ve gorsellerini fligransiz indirin.",
  "permissions": [
    "downloads",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.meta.ai/*",
    "https://*.fbcdn.net/*",
    "https://*.cdninstagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.meta.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Meta AI Media Downloader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
